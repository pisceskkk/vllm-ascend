        else:
            for i in range(B):
                if start_pos[i] + S > S_max:
                    print(f"Error: for batch {i} when shape of x is (B, S, hidden_size), start_pos[{i}] + S > S_max, start_pos[{i}]={start_pos[i]}, S={S}, S_max={S_max}")
                    return
                if seqused is not None:
                    if seqused[i] > S:
