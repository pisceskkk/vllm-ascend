        if bs_combine_flag:
            for i in range(B):
                if start_pos[i] + (cu_seqlens[i + 1] - cu_seqlens[i]) > S_max:
                    print(f"Error: for batch {i} when shape of x is (T, hidden_size), start_pos[{i}] + (cu_seqlens[{i + 1}] - cu_seqlens[{i}]) > S_max, "
