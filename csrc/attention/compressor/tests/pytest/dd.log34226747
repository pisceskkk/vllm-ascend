B = 1, S_max = tensor(8193, dtype=torch.int32), head_dim = 128, coff = 2
cmp_ratio = 4, bs_combine_flag = True, S = tensor(1, dtype=torch.int32)
start_pos = tensor([8192], device='npu:0', dtype=torch.int32), seqused = None
