        print(f"rope_cos: shape {rope_cos.shape}, dtype: {rope_cos.dtype}")
        print(f"block_table: shape {block_table.shape}, dtype: {block_table.dtype}")
        print(f"cmp_kv: shape {npu_out.shape}, dtype: {npu_out.dtype}")
    
