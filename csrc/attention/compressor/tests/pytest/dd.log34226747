                            f"seqused[{i}]={seqused[i]}, cu_seqlens[{i + 1}]={cu_seqlens[i + 1]}, cu_seqlens[{i}]={cu_seqlens[i]}")
                        return
        else:
            for i in range(B):
                if start_pos[i] + S > S_max:
