B = 8, S_max = tensor(8194, dtype=torch.int32), head_dim = 128, coff = 2
cmp_ratio = 4, bs_combine_flag = True, S = tensor(3, dtype=torch.int32)
start_pos = tensor([8191, 8191, 8191, 8191, 8191, 8191, 8191, 8191], device='npu:0',
