        else:
            x_shape = (B, S, hidden_size)
            rope_sin_shape = (B, (S + cmp_ratio - 1) // cmp_ratio, rope_head_dim)
            rope_cos_shape = rope_sin_shape
    
        x = torch.tensor(np.random.uniform(x_datarange[0], x_datarange[1], x_shape)).to(data_type)
